# ─── SERVER ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE (Railway MySQL) ──────────────────────────────
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=dudes_and_duds

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1d

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─── PAYMONGO (Philippine payments) ──────────────────────
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_key
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_key
PAYMONGO_WEBHOOK_SECRET=whsk_your_webhook_secret
